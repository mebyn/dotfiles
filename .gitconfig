[user]
  email = melvin.sy@outlook.com
  name = Melvin
[includeIf "gitdir:~/Code/ImportGenius/"]
  path = ~/.gitconfig-ig
[http]
  postBuffer = 524288000
[gitmoji]
  enable = true
[rerere]
	enabled = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[init]
  defaultBranch = master
[core]
  editor = vim
  autocrlf = input
  fscache = true
  whitespace = cr-at-eol
  eol = lf
  pager = delta
[color]
  diff = auto
  status = auto
  branch = auto
[pull]
  rebase = true
[rebase]
  autosquash = true
  autoStash = true
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  line-numbers = true
  hyperlinks = true
  side-by-side = false
[merge]
  conflictstyle = zdiff3
[diff]
  colorMoved = default
[alias]
  all = "!f() { ls -R -d */.git | xargs -I{} bash -c \"echo {} && git -C {}/../ $*\"; }; f"
  sweep = "!f() { git branch --merged | egrep -v \"(^\\*|master|main)\" | xargs git branch -d; }; f"
  rema = pull --rebase origin master
  pfl = push --force-with-lease
  ptr = push -u origin HEAD

  ac = !git add -A && git commit
  ca = commit --amend

  # Git reset
  re1 = reset HEAD^
  res = reset --soft HEAD^

  # Git list aliases
  la = !git config -l | grep alias | cut -c 7-

  # Skip-worktree (unique, no OMZ/forgit equivalent)
  hide = update-index --skip-worktree
  unhide = update-index --no-skip-worktree
  unhide-all = ls-files -v | grep -i ^S | cut -c 3- | xargs git update-index --no-skip-worktree
  hidden = ! git ls-files -v | grep '^S' | cut -c3-
[push]
  autoSetupRemote = true
